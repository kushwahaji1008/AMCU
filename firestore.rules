rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: farmers
    // Fields: farmerId, name, mobile, village, cattleType, bankAccount, ifsc, status, createdAt
    //
    // Collection: collections
    // Fields: txnId, timestamp, shift, farmerId, farmerName, milkType, quantity, fat, snf, clr, rate, amount, operatorId
    //
    // Collection: rateCharts
    // Fields: effectiveFrom, milkType, baseRate, fatStandard, snfStandard, fatStep, snfStep
    //
    // Collection: shiftSummaries
    // Fields: date, shift, totalFarmers, totalQuantity, avgFat, avgSnf, amount, closedAt, closedBy
    //
    // Collection: payments
    // Fields: farmerId, farmerName, amount, method, reference, date, timestamp, operatorId, status
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      // Always fetch user profile from the default database (Registry)
      return get(/databases/(default)/documents/users/$(request.auth.uid)).data;
    }

    function isSuperAdmin() {
      return isAuthenticated() && getUserData().role == 'super_admin';
    }

    function isAdmin() {
      return isAuthenticated() && (getUserData().role == 'admin' || isSuperAdmin());
    }

    function isOperator() {
      return isAuthenticated() && (getUserData().role == 'operator' || isAdmin());
    }

    function getDairyId() {
      return getUserData().dairyId;
    }

    function isDairyOwner(data) {
      return isSuperAdmin() || (data.dairyId == getDairyId());
    }

    // Validation Functions
    function isValidFarmer(data) {
      return data.farmerId is string && data.farmerId.size() > 0 &&
             data.name is string && data.name.size() > 0 &&
             data.village is string &&
             data.cattleType in ['Cow', 'Buffalo', 'Mixed'] &&
             data.status in ['Active', 'Inactive'] &&
             data.dairyId is string && data.dairyId.size() > 0;
    }

    function isValidCollection(data) {
      return data.farmerId is string &&
             data.quantity is number && data.quantity > 0 &&
             data.fat is number && data.fat >= 0 &&
             data.snf is number && data.snf >= 0 &&
             data.amount is number && data.amount >= 0 &&
             data.dairyId is string && data.dairyId.size() > 0;
    }

    function isValidPayment(data) {
      return data.farmerId is string &&
             data.farmerName is string &&
             data.amount is number && data.amount > 0 &&
             data.method in ['Cash', 'UPI', 'Check'] &&
             data.date is string &&
             data.status in ['Completed', 'Pending'] &&
             data.dairyId is string && data.dairyId.size() > 0;
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isSuperAdmin() || (isAdmin() && resource.data.adminId == request.auth.uid));
      allow create: if isAuthenticated() && (request.auth.uid == userId || (isAdmin() && request.resource.data.role == 'operator' && request.resource.data.adminId == request.auth.uid));
      allow update: if isSuperAdmin() || (isAuthenticated() && request.auth.uid == userId && request.resource.data.role == resource.data.role);
      allow delete: if isSuperAdmin();
    }

    match /farmers/{farmerId} {
      allow read: if isAuthenticated() && isDairyOwner(resource.data);
      allow create: if isOperator() && isValidFarmer(request.resource.data) && isDairyOwner(request.resource.data);
      allow update: if isOperator() && isValidFarmer(request.resource.data) && isDairyOwner(resource.data) && isDairyOwner(request.resource.data);
      allow delete: if isAdmin() && isDairyOwner(resource.data);
    }

    match /collections/{txnId} {
      allow read: if isAuthenticated() && isDairyOwner(resource.data);
      allow create: if isOperator() && isValidCollection(request.resource.data) && isDairyOwner(request.resource.data);
      allow update: if isAdmin() && isDairyOwner(resource.data) && isDairyOwner(request.resource.data);
      allow delete: if isAdmin() && isDairyOwner(resource.data);
    }

    match /rateCharts/{chartId} {
      allow read: if isAuthenticated() && isDairyOwner(resource.data);
      allow write: if isAdmin() && isDairyOwner(request.resource.data);
    }

    match /shiftSummaries/{summaryId} {
      allow read: if isAuthenticated() && isDairyOwner(resource.data);
      allow create, update: if isOperator() && isDairyOwner(request.resource.data);
      allow delete: if isAdmin() && isDairyOwner(resource.data);
    }

    match /settings/{settingId} {
      allow read: if isAuthenticated() && isDairyOwner(resource.data);
      allow write: if isAdmin() && isDairyOwner(request.resource.data);
    }

    match /auditLogs/{logId} {
      allow read: if isAdmin() && isDairyOwner(resource.data);
      allow create: if isAuthenticated() && isDairyOwner(request.resource.data);
      allow update, delete: if false;
    }

    match /backups/{backupId} {
      allow read, write: if isAdmin() && isDairyOwner(resource.data);
    }

    match /payments/{paymentId} {
      allow read: if isAuthenticated() && isDairyOwner(resource.data);
      allow create: if isOperator() && isValidPayment(request.resource.data) && isDairyOwner(request.resource.data);
      allow update: if isAdmin() && isDairyOwner(resource.data) && isDairyOwner(request.resource.data);
      allow delete: if isAdmin() && isDairyOwner(resource.data);
    }

    match /ledger/{entryId} {
      allow read: if isAuthenticated() && isDairyOwner(resource.data);
      allow create: if isOperator() && isDairyOwner(request.resource.data);
      allow update, delete: if false;
    }
  }
}
